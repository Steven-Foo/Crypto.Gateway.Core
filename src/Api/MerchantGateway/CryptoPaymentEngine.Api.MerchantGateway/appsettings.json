{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Chains": {
    "Tron": {
      "RpcBaseUrl": "https://api.trongrid.io",
      "ApiKey": ""
    }
  },
  "Deposit": {
    "Policies": {
      "Tron": { "CreditStrategy": "Confirmations", "Confirmations": 19, "MinDepositBaseUnits": "1000000" },
      "Ethereum": { "CreditStrategy": "Confirmations", "Confirmations": 12, "MinDepositBaseUnits": "10000000000000000" },
      "Solana": { "CreditStrategy": "Finalized", "Confirmations": 0, "MinDepositBaseUnits": "1000000" }
    }
  },
  "Withdrawal": {
    "Policies": {
      "Tron": { "MinimumBaseUnits": "1000000", "MaximumBaseUnits": "", "FeeBaseUnits": "1000000", "ApprovalThresholdBaseUnits": "1000000000", "Confirmations": 19 },
      "Ethereum": { "MinimumBaseUnits": "10000000000000000", "MaximumBaseUnits": "", "FeeBaseUnits": "2000000000000000", "ApprovalThresholdBaseUnits": "1000000000000000000", "Confirmations": 12 },
      "Solana": { "MinimumBaseUnits": "1000000", "MaximumBaseUnits": "", "FeeBaseUnits": "500000", "ApprovalThresholdBaseUnits": "1000000000", "Confirmations": 32 }
    },
    "HotWallets": {
      "Tron": { "Address": "TReplaceWithRealHotWalletAddress", "KeyReference": "kms://tron/hot/0" }
    }
  },
  "AllowedHosts": "*"
}
